{
  "manifest_version": 3,
  "name": "NDM Integration",
  "version": "1.1",
  "description": "Automatic Download Interception for NDM",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5555/*"
  ]
}
